{
  "name": "prepzify-backend",
  "version": "1.0.0",
  "description": "Prepzify Express API server — handles Gemini AI and all backend routes",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "esbuild server.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.js",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@types/nodemailer": "^8.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.0",
    "express": "^4.21.2",
    "nodemailer": "^8.0.8",
    "razorpay": "^2.9.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
