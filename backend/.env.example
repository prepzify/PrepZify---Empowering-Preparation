# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Required. Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ───────────────────────────────────────────────────────────────────────
# Production frontend URL (e.g., https://prepzify.com)
# Leave blank in local dev — localhost:5173 and localhost:4173 are always allowed.
FRONTEND_URL=

# ── Razorpay Payments ─────────────────────────────────────────────────────────
# Get these from Razorpay Dashboard > Account & Settings > API Keys.
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
