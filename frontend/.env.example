# ── Backend API URL ─────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT: Set to http://localhost:3000 (Vite proxies /api/* to this URL).
# PRODUCTION (Vercel): Set to your full Railway backend URL, e.g.:
#   VITE_API_URL=https://prepzify-backend.up.railway.app
VITE_API_URL=http://localhost:3000

# ── Razorpay Public Key ───────────────────────────────────────────────────────
# This key is safe to expose in the browser.
# Use your live key (rzp_live_...) in production.
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id
