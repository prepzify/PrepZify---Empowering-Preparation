# ── Backend API URL ─────────────────────────────────────────────────────────────
# In development, Vite proxies /api/* to this URL automatically.
# In production, this can be left blank if frontend and backend share a domain,
# or set to the full backend URL (e.g., https://api.prepzify.com).
VITE_API_URL=http://localhost:3000

# Public Razorpay key id. This is safe to expose in the browser.
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id
